# ============================================================
#  Pisade Frontend — Environment Variables
#  Copy this file to .env.local and fill in every value.
#  Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# ============================================================

# ------------------------------------------------------------
# NextAuth
# NEXTAUTH_URL must exactly match the URL the app is served at.
# NEXTAUTH_SECRET: openssl rand -base64 32
# ------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
AUTH_TRUST_HOST=true   # set to true when behind a reverse proxy

# ------------------------------------------------------------
# Backend URLs
# BACKEND_URL      — used server-side (Next.js API routes, auth callbacks)
# NEXT_PUBLIC_BACKEND_URL — used client-side (browser fetch / axios)
# These should point to the same server; just different network paths.
# ------------------------------------------------------------
BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ------------------------------------------------------------
# Google OAuth
# Must match the credentials registered in the Google Cloud Console.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID is used by the Google Identity button.
# ------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------
# Stripe (client-side publishable key only)
# ------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ------------------------------------------------------------
# Email  (NextAuth email provider — optional)
# Only needed if you enable the built-in NextAuth email provider.
# The backend handles magic-link mail; leave blank if unused.
# ------------------------------------------------------------
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="Pisade <noreply@example.com>"
